# Example config for Pulumi stack `dev`.
# Do not commit real values — copy this file to `Pulumi.dev.yaml` and edit, OR
# use `pulumi config set ...` for sensitive values.

config:
  aws:region: us-east-1

  # Engine: "analytics" (Neptune Analytics, default) or "db" (Neptune Database)
  neptune-min:engine: analytics

  # ─── analytics-only (ignored when engine=db) ────────────────────────────
  # Default 16 m-NCU; smallest supported value. Billed per hour while the graph
  # exists — `pulumi destroy` between sessions to stop the bill.
  # neptune-min:provisionedMemory: 16
  # Dimension of the embedding model Bedrock will use (Titan v2 = 1024).
  # neptune-min:vectorSearchDimension: 1024

  # ─── db-only (REQUIRED when engine=db, ignored otherwise) ───────────────
  # EC2 keypair name for SSH to the bastion. Mandatory when engine=db.
  neptune-min:keyName: my-ec2-keypair-name
  # Your laptop's public IPv4 in CIDR form. Mandatory when engine=db.
  neptune-min:myIp: "203.0.113.10/32"   # replace with YOUR public IP /32
  # Optional: smallest non-serverless Neptune DB instance (default)
  # neptune-min:instanceClass: db.r5.large